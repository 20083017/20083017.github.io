#!/usr/bin/python3

import os
import re

#app_agent_list = list(range(3950000000,3950000001))

f = open("employeeUid.txt")

line = f.readline()

uid_list = []

while line:
    line = line.rstrip()
    line = line.lstrip()
    if line is not None:
    	uid_list.append(int(line))
        #print(int(line))
    line = f.readline()
    #print(int(line))
f.close()

f = open("puids.txt")

line = f.readline()

app_agent_list = []

while line:
    line = line.rstrip()
    line = line.lstrip()
    app_agent_list.append(3950000000 + int(line))
    line = f.readline()

f.close()

m = list(range(0,3067))

#print(app_agent_list)
#print(uid_list)
#print(len(m))

mp = dict.fromkeys(m)
for app_agent in app_agent_list:
    # print(mp)
    mp1 = dict.fromkeys(m)
    for uid in uid_list:
        # print(i)
        # print(j)
        comuid = min(uid,app_agent) << 32 | max(uid,app_agent)
        # print(comuid)
        # print(len(m))
        index = comuid%len(m)
        #print(index)
        if mp[index] is None:
            mp[index] = 1
            # print(mp[index])
        else:
            mp[index] += 1
            # print(mp[index])
        if mp1[index] is None:
           mp1[index] = 1
        else:
           mp1[index] += 1
    for v in mp1:
        print(str(v) + " " + str(mp1[v]))
for v in mp:
    print(str(v) + " " + str(mp[v]))
